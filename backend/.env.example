# Database (NeonDB PostgreSQL connection string)
DATABASE_URL=postgresql://neondb_owner:[PASSWORD]@ep-xxx-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require

# Supabase JWT Secret (Dashboard → Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Server
PORT=3001

# CORS — Frontend origin
FRONTEND_URL=http://localhost:3000
